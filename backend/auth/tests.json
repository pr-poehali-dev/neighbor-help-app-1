{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/register",
      "body": {"name": "Тест Тестов", "email": "test_unique_7745@example.com", "password": "password123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/login",
      "body": {"email": "test_unique_7745@example.com", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with correct password",
      "method": "POST",
      "path": "/login",
      "body": {"email": "test_unique_7745@example.com", "password": "password123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Register duplicate email",
      "method": "POST",
      "path": "/register",
      "body": {"name": "Другой", "email": "test_unique_7745@example.com", "password": "password123"},
      "expectedStatus": 409,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}